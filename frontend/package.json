{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "rimraf .next out coverage",
    "lint": "eslint",
    "lint:oxlint": "oxlint",
    "lint:fix": "ultracite fix",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@libsql/client": "^0.17.3",
    "@logtape/logtape": "^2.1.3",
    "@t3-oss/env-nextjs": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "^6.1.3",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lingual/i18n-check": "^0.9.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ultracite": "^7.8.3",
    "vitest": "^4.1.8"
  }
}
